generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum ReminderType {
  DM
  ROLE_PING
}

model GuildConfig {
  guildId String @id

  upcomingEventsChannelId String?
  reminderChannelId       String?
  pingRoleId              String?

  // JSON array of minute offsets before event pings, e.g. [720, 60]
  dmReminderOffsetsMinutes   String @default("[720,60]")
  roleReminderOffsetsMinutes String @default("[60,2]")
  eventExpiryOffsetMinutes   Int    @default(90)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ScheduledEvent {
  id String @id @default(cuid())

  guildId String

  title    String
  startsAt DateTime

  creatorUserId String

  signupChannelId String?
  signupMessageId String?

  signups      ScheduledSignup[]
  reminderLogs ReminderLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([guildId, startsAt])
}

model ScheduledSignup {
  id String @id @default(cuid())

  eventId String
  userId  String

  event ScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([eventId, userId])
  @@index([userId])
}

model ReminderLog {
  id String @id @default(cuid())

  eventId       String
  offsetMinutes Int
  type          ReminderType

  event ScheduledEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  sentAt DateTime @default(now())

  @@unique([eventId, offsetMinutes, type])
}
